{
  "platforms": {
    "apifox": {
      "default": {
        "token": "replace_with_apifox_access_token"
      },
      "team_a": {
        "token": "replace_with_team_a_apifox_access_token"
      }
    },
    "tapd": {
      "default": {
        "token": "replace_with_tapd_personal_token"
      }
    }
  },
  "llm": {
    "base_url": "https://api.anthropic.com",
    "api_key": "replace_with_your_api_key",
    "model": "MiMo-V2.5-Pro",
    "max_tokens": 8192,
    "timeout": 10
  },
  "databases": {
    "saas": {
      "type": "mysql",
      "host": "replace_with_saas_db_host",
      "port": 3306,
      "user": "replace_with_saas_db_user",
      "password": "replace_with_saas_db_password",
      "description": "SAAS database connection"
    },
    "shark": {
      "type": "mysql",
      "host": "replace_with_shark_db_host",
      "port": 3306,
      "user": "replace_with_shark_db_user",
      "password": "replace_with_shark_db_password",
      "description": "Shark database connection"
    },
    "silkroad": {
      "type": "mysql",
      "host": "replace_with_silkroad_db_host",
      "port": 3306,
      "user": "replace_with_silkroad_db_user",
      "password": "replace_with_silkroad_db_password",
      "description": "Silkroad database connection"
    }
  }
}
