{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EndpointMapping",
  "type": "object",
  "required": ["requirement_id", "mappings"],
  "properties": {
    "requirement_id": {
      "type": "string"
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_case_id", "automation_id", "path", "method"],
        "properties": {
          "test_case_id": {
            "type": "string"
          },
          "automation_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "method": {
            "type": "string"
          }
        }
      }
    }
  }
}
