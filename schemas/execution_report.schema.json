{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionReport",
  "type": "object",
  "required": ["run_id", "pytest_exit_code", "generated_test_count", "summary"],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "pytest_exit_code": {
      "type": "integer"
    },
    "generated_test_count": {
      "type": "integer"
    },
    "summary": {
      "type": "object",
      "required": ["passed", "failed", "skipped"],
      "properties": {
        "passed": {
          "type": "integer"
        },
        "failed": {
          "type": "integer"
        },
        "skipped": {
          "type": "integer"
        }
      }
    }
  }
}
