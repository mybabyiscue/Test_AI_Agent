{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestCases",
  "type": "object",
  "required": ["requirement_id", "cases"],
  "properties": {
    "requirement_id": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_case_id", "title", "type", "expected_status_codes"],
        "properties": {
          "test_case_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "expected_status_codes": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
